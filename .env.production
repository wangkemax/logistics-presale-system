# =====================================================
# 生产环境配置 - 部署前务必修改所有 changeme 项
# =====================================================

# ── LLM API Keys ──
ANTHROPIC_API_KEY=sk-ant-你的key
OPENAI_API_KEY=                    # 可选备用
DEEPSEEK_API_KEY=                  # 可选备用
MINIMAX_API_KEY=                   # 可选备用
LLM_PRIMARY_MODEL=claude-sonnet-4-20250514
LLM_FALLBACK_MODEL=gpt-4o

# ── 数据库 ──
DB_USER=postgres
DB_PASSWORD=changeme_db_password_here
DATABASE_URL=postgresql+asyncpg://postgres:changeme_db_password_here@db:5432/logistics_presale

# ── Redis ──
REDIS_PASSWORD=changeme_redis_password_here
REDIS_URL=redis://:changeme_redis_password_here@redis:6379/0

# ── MinIO 文件存储 ──
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=changeme_minio_password_here
S3_BUCKET=logistics-presale

# ── 应用 ──
APP_SECRET_KEY=changeme_random_secret_key_at_least_32_chars
APP_ENV=production
APP_DEBUG=false

# ── CORS（改成你的域名）──
CORS_ORIGINS=https://你的域名.com

# ── Agent 配置 ──
AGENT_DEFAULT_TIMEOUT_MINUTES=10
AGENT_MAX_RETRIES=2
