# ======================
# LLM Configuration
# ======================
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx           # Backup LLM
LLM_PRIMARY_MODEL=claude-sonnet-4-20250514
LLM_FALLBACK_MODEL=gpt-4o

# ======================
# Database
# ======================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/logistics_presale
REDIS_URL=redis://redis:6379/0

# ======================
# Vector Database (Milvus)
# ======================
MILVUS_HOST=milvus
MILVUS_PORT=19530
EMBEDDING_MODEL=text-embedding-3-small

# ======================
# Object Storage
# ======================
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=logistics-presale

# ======================
# Application
# ======================
APP_SECRET_KEY=change-this-to-a-random-secret-key
APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=http://localhost:3000

# ======================
# Agent Configuration
# ======================
AGENT_DEFAULT_TIMEOUT_MINUTES=10
AGENT_MAX_RETRIES=2
